generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Car {
  id           Int        @id @default(autoincrement())
  brand        String
  model        String
  year         Int
  price        Float
  category     String
  transmission String
  fuel         String
  seats        Int        @default(5)
  ac           Boolean    @default(true)
  status       String     @default("available")
  image        String
  descEn       String     @default("") @map("desc_en")
  descFr       String     @default("") @map("desc_fr")
  descAr       String     @default("") @map("desc_ar")
  descEs       String     @default("") @map("desc_es")
  featured     Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  bookings     Booking[]
  images       CarImage[]

  @@map("cars")
}

model CarImage {
  id        Int      @id @default(autoincrement())
  url       String
  alt       String   @default("")
  order     Int      @default(0)
  carId     Int
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("car_images")
}

model Booking {
  id         Int      @id @default(autoincrement())
  name       String
  email      String
  phone      String
  pickupDate DateTime @map("pickup_date")
  returnDate DateTime @map("return_date")
  pickupCity String   @default("Marrakech") @map("pickup_city")
  status     String   @default("pending")
  notes      String   @default("")
  totalPrice Float    @default(0) @map("total_price")
  carId      Int
  car        Car      @relation(fields: [carId], references: [id])
  lang       String   @default("en")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("bookings")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String   @default("")
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model SiteSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("site_settings")
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  city      String
  text      String   @db.Text
  rating    Int      @default(5)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}
